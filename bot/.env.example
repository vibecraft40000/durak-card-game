# Telegram bot token from BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Admin Telegram ID (use @userinfobot)
ADMIN_IDS=YOUR_ADMIN_ID_HERE

# Mini App URL (your domain or localhost)
WEBAPP_URL=http://127.0.0.1:5173
# Webhook URL (empty = polling mode)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook

# Backend API URL for admin panel
API_BASE_URL=http://127.0.0.1:8080
ADMIN_SECRET=change-me-in-production

# Optional: channel subscription gate
# REQUIRED_CHANNEL_ID=
# CHANNEL_INVITE_LINK=https://t.me/your_channel

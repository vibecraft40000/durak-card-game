# Токен бота (например @durakton777_bot). Не коммитьте реальный токен.
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Telegram ID админа (узнать: @userinfobot). Только этот пользователь может вызывать /admin.
ADMIN_IDS=YOUR_ADMIN_ID_HERE

# URL, где открывается игра (Web App). Для прода — ваш домен.
WEBAPP_URL=https://durakonline.duckdns.org
# Публичный HTTPS для приёма апдейтов бота. Пусто = режим polling (удобно для разработки).
WEBHOOK_URL=
WEBHOOK_PATH=/webhook

# Опционально: для кнопки «Статистика» в админке (данные с бэкенда).
# API_BASE_URL=https://api.your-domain.com
# ADMIN_SECRET=ваш-секретный-ключ

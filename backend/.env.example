ENV=staging
PORT=8080
PPROF_PORT=6060
POSTGRES_URL=postgres://durak:durak@127.0.0.1:5432/durak?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
TELEGRAM_BOT_TOKEN=123456:replace-with-real-bot-token
ALLOW_DEV_TELEGRAM_AUTH=false
JWT_SECRET=replace-with-32-plus-char-jwt-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
TELEGRAM_INIT_MAX_AGE=24h
AUTH_REPLAY_TTL=24h
MATCH_STATE_TTL=2h
DISCONNECT_POLICY=abandon
WS_SYNC_DIFF_SKIP_FINAL_STATE=false
ALLOWED_ORIGIN=http://127.0.0.1:5173
ADMIN_SECRET=replace-with-long-admin-secret
# ADMIN_NOTIFY_TELEGRAM_IDS=
# REQUIRED_CHANNEL_ID=
# SUBSCRIPTION_CHANNEL_LINK=https://t.me/your_channel

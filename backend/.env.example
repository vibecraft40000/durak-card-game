PORT=8080
PPROF_PORT=6060
POSTGRES_URL=postgres://durak:durak@localhost:5432/durak?sslmode=disable
REDIS_URL=redis://localhost:6379/0
TELEGRAM_BOT_TOKEN=dev-bot-token
JWT_SECRET=dev-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
TELEGRAM_INIT_MAX_AGE=24h
AUTH_REPLAY_TTL=24h
MATCH_STATE_TTL=2h
COMMISSION_BPS=300
ALLOWED_ORIGIN=http://localhost:5173

# FX conversion rates: 1 unit of currency -> USD
FX_RATES_USD_PER_UNIT=USD:1,USDT:1,UAH:0.024,RUB:0.011,EUR:1.08

# Withdraw fee (basis points): card=2%, crypto=0%
WITHDRAW_FEE_CARD_BPS=200
WITHDRAW_FEE_CRYPTO_BPS=0

# Admin API secret for /admin/*
# ADMIN_SECRET=your-secret

# Telegram chat IDs to notify about withdraw requests (comma-separated)
# ADMIN_NOTIFY_TELEGRAM_IDS=5521738246

# Секрет Flask (сессии). Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-in-production

# Первый админ (создаётся при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=сложный-пароль

# API бэкенда (Go) — тот же ADMIN_SECRET, что и в backend/.env
API_BASE_URL=https://durakonline.duckdns.org
ADMIN_SECRET=ваш-секретный-ключ

# Опционально: своя БД для админов (по умолчанию SQLite admin_data.db)
# ADMIN_DATABASE_URI=sqlite:///admin_data.db

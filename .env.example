VITE_USE_MOCK_API=true
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
# VITE_PROXY_TARGET=http://localhost:8090  # для Docker/nginx, иначе 8080
# Имя бота в Telegram (без @) для ссылок приглашения, например: durakton777_bot
VITE_TELEGRAM_BOT_USERNAME=durakton777_bot
# Опционально: short name Mini App из BotFather (если нужен формат /<short_name>?startapp=...)
# Если пусто, будет использоваться https://t.me/<bot>?startapp=...
VITE_TELEGRAM_MINIAPP_SHORT_NAME=
# Защита от повторного использования initData. Включать только если точно не ломает логин клиентов Telegram.
STRICT_INITDATA_REPLAY=false
